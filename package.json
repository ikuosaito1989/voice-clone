{
  "name": "voice-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "create:user": "node --experimental-strip-types scripts/create-user.ts",
